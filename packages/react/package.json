{
  "name": "@react-perfscope/react",
  "version": "0.2.0",
  "description": "React render collector for react-perfscope.",
  "keywords": [
    "react",
    "performance",
    "profiler",
    "render",
    "re-render",
    "devtools"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node scripts/prepend-dts-refs.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-perfscope/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@testing-library/react": "^16.0.0"
  },
  "license": "MIT",
  "author": "rayforvideos",
  "homepage": "https://github.com/rayforvideos/react-perfscope#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rayforvideos/react-perfscope.git",
    "directory": "packages/react"
  },
  "bugs": "https://github.com/rayforvideos/react-perfscope/issues",
  "publishConfig": {
    "access": "public"
  }
}
