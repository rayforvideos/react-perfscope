{
  "name": "@react-perfscope/core",
  "version": "0.3.0",
  "description": "Recorder and signal collectors for react-perfscope.",
  "keywords": [
    "react",
    "performance",
    "profiler",
    "web-vitals",
    "long-tasks",
    "layout-shift",
    "devtools"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node scripts/prepend-dts-refs.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.25",
    "web-vitals": "^4.0.0"
  },
  "license": "MIT",
  "author": "rayforvideos",
  "homepage": "https://github.com/rayforvideos/react-perfscope#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rayforvideos/react-perfscope.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/rayforvideos/react-perfscope/issues",
  "publishConfig": {
    "access": "public"
  }
}
