{
  "name": "react-perfscope",
  "version": "0.7.1",
  "description": "Zero-config React performance profiler with an in-app panel.",
  "keywords": [
    "react",
    "performance",
    "profiler",
    "web-vitals",
    "inp",
    "render",
    "long-tasks",
    "layout-shift",
    "memory",
    "fps",
    "devtools"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "import": "./dist/auto.js",
      "require": "./dist/auto.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/auto.js",
    "./dist/auto.cjs"
  ],
  "scripts": {
    "build": "tsup && node scripts/prepend-dts-refs.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-perfscope/core": "workspace:*",
    "@react-perfscope/react": "workspace:*",
    "@react-perfscope/ui": "workspace:*"
  },
  "license": "MIT",
  "author": "rayforvideos",
  "homepage": "https://github.com/rayforvideos/react-perfscope#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rayforvideos/react-perfscope.git",
    "directory": "packages/meta"
  },
  "bugs": "https://github.com/rayforvideos/react-perfscope/issues",
  "publishConfig": {
    "access": "public"
  }
}
