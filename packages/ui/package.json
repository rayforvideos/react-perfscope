{
  "name": "@react-perfscope/ui",
  "version": "0.7.0",
  "description": "In-app performance panel and overlays for react-perfscope.",
  "keywords": [
    "react",
    "performance",
    "profiler",
    "devtools",
    "ui",
    "panel"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && node scripts/prepend-dts-refs.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-perfscope/core": "workspace:*",
    "preact": "^10.20.0"
  },
  "devDependencies": {
    "@react-perfscope/react": "workspace:*",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "license": "MIT",
  "author": "rayforvideos",
  "homepage": "https://github.com/rayforvideos/react-perfscope#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rayforvideos/react-perfscope.git",
    "directory": "packages/ui"
  },
  "bugs": "https://github.com/rayforvideos/react-perfscope/issues",
  "publishConfig": {
    "access": "public"
  }
}
